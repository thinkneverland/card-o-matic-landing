---
const steps = [
  {
    number: "01",
    title: "Read the Codebase",
    description: "Claude uses its built-in file tools to explore your project structure, reading source files, tests, and configuration.",
    icon: "folder-open",
    color: "#2d6a4f",
  },
  {
    number: "02",
    title: "Analyze the Project",
    description: "The `analyze_project` tool scans your directory for framework, language, test setup, key directories, and coding patterns.",
    icon: "cpu",
    color: "#c9a227",
  },
  {
    number: "03",
    title: "Load Atlas Context",
    description: "The `atlas_context` tool reads `.atlas/` docs and playbooks for project-specific conventions, AC suggestions, and TC hints.",
    icon: "book-open",
    color: "#7c3aed",
  },
  {
    number: "04",
    title: "Format the Card",
    description: "Using `format_card_linear` or `format_card_jira`, Claude structures the issue with your description, relevant files, AC, TC, and AI guidance.",
    icon: "layout",
    color: "#2d6a4f",
  },
  {
    number: "05",
    title: "Create the Issue",
    description: "`create_card_linear` or `create_card_jira` combines formatting and creation in one step — the issue lands in your tracker instantly.",
    icon: "send",
    color: "#c9a227",
  },
];
---

<section id="how-it-works" class="py-24 px-6" style="background-color: var(--color-parchment);">
  <!-- Vine divider top -->
  <div class="divider-vines h-5 mb-16 opacity-40"></div>

  <div class="max-w-5xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold mb-4" style="background-color: var(--color-gold-pale); color: var(--color-gold); border: 1px solid rgba(201,162,39,0.3);">
        🗺 How It Works
      </div>
      <h2 class="text-4xl sm:text-5xl font-bold mb-4" style="font-family: var(--font-display); color: var(--color-forest-dark);">
        From codebase to card<br/>in five steps
      </h2>
      <p class="text-lg max-w-2xl mx-auto" style="color: var(--color-bark-light);">
        Card-O-Matic works as your AI agent's workshop. Each tool plays a precise role in the journey from raw code to structured issue.
      </p>
    </div>

    <!-- Steps -->
    <div class="relative">
      <!-- Connecting line (desktop) -->
      <div class="hidden lg:block absolute left-1/2 top-12 bottom-12 w-0.5 -translate-x-1/2" style="background: linear-gradient(to bottom, var(--color-forest), var(--color-gold), var(--color-fairy), var(--color-forest), var(--color-gold)); opacity: 0.2;"></div>

      <div class="flex flex-col gap-10">
        {steps.map((step, i) => (
          <div class={`flex flex-col lg:flex-row items-center gap-6 lg:gap-10 ${i % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
            <!-- Content card -->
            <div class="flex-1 rounded-2xl p-7 transition-all duration-300 hover:shadow-lg hover:-translate-y-1" style="background-color: var(--color-cream); border: 1.5px solid var(--color-parchment-dark);">
              <div class="flex items-start gap-4">
                <!-- Step icon -->
                <div class="flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center" style={`background: ${step.color}20;`}>
                  {step.icon === "folder-open" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={step.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                      <polyline points="8 14 12 18 16 14"/>
                      <line x1="12" y1="10" x2="12" y2="18"/>
                    </svg>
                  )}
                  {step.icon === "cpu" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={step.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/>
                      <line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/>
                      <line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/>
                      <line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/>
                      <line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/>
                    </svg>
                  )}
                  {step.icon === "book-open" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={step.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                      <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                    </svg>
                  )}
                  {step.icon === "layout" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={step.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="3" width="18" height="18" rx="2"/>
                      <line x1="3" y1="9" x2="21" y2="9"/>
                      <line x1="9" y1="21" x2="9" y2="9"/>
                    </svg>
                  )}
                  {step.icon === "send" && (
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke={step.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="22" y1="2" x2="11" y2="13"/>
                      <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                    </svg>
                  )}
                </div>

                <div class="flex-1">
                  <h3 class="text-lg font-semibold mb-2" style="font-family: var(--font-display); color: var(--color-forest-dark);">
                    {step.title}
                  </h3>
                  <p class="text-sm leading-relaxed" style="color: var(--color-bark-light);" set:html={step.description.replace(/`([^`]+)`/g, `<code class="px-1.5 py-0.5 rounded text-xs font-mono" style="background-color:var(--color-parchment-dark);color:var(--color-forest-dark);">$1</code>`)} />
                </div>
              </div>
            </div>

            <!-- Step number bubble (center) -->
            <div class="flex-shrink-0 w-14 h-14 rounded-full flex items-center justify-center z-10 font-bold text-lg shadow-md" style={`background: ${step.color}; color: white; font-family: var(--font-display);`}>
              {step.number}
            </div>

            <!-- Spacer on alternating side -->
            <div class="flex-1 hidden lg:block"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- Or use combined tools callout -->
    <div class="mt-14 text-center p-8 rounded-2xl" style="background: linear-gradient(135deg, var(--color-gold-pale) 0%, var(--color-parchment) 100%); border: 1.5px solid rgba(201,162,39,0.25);">
      <div class="text-3xl mb-3">✨</div>
      <h3 class="text-xl font-bold mb-2" style="font-family: var(--font-display); color: var(--color-forest-dark);">
        Or skip to one-step creation
      </h3>
      <p class="text-sm max-w-lg mx-auto mb-4" style="color: var(--color-bark-light);">
        Use <code class="px-1.5 py-0.5 rounded font-mono text-xs" style="background-color: var(--color-parchment-dark); color: var(--color-forest-dark);">create_card_linear</code> or <code class="px-1.5 py-0.5 rounded font-mono text-xs" style="background-color: var(--color-parchment-dark); color: var(--color-forest-dark);">create_card_jira</code> — combined tools that format the card body and create the issue in a single MCP call. The magic shortcut.
      </p>
      <a href="#card-format" class="inline-flex items-center gap-2 text-sm font-semibold" style="color: var(--color-gold);">
        See the card format
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  </div>
</section>
