---

---

<footer
  class="py-16 px-6"
  style="background: linear-gradient(180deg, var(--color-parchment) 0%, var(--color-parchment-dark) 100%); border-top: 1.5px solid var(--color-parchment-dark);"
>
  <div class="divider-vines h-5 mb-14 opacity-50"></div>

  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Brand column -->
      <div class="lg:col-span-2">
        <!-- Logo -->
        <div class="flex items-center gap-2.5 mb-4">
          <div
            class="w-9 h-9 rounded-xl flex items-center justify-center"
            style="background-color: var(--color-forest);"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 64 64"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <rect
                x="10"
                y="14"
                width="44"
                height="36"
                rx="5"
                fill="white"
                opacity="0.95"></rect>
              <rect x="17" y="22" width="30" height="3" rx="1.5" fill="#2d6a4f"
              ></rect>
              <rect x="17" y="29" width="22" height="2" rx="1" fill="#94a3b8"
              ></rect>
              <rect x="17" y="35" width="16" height="2" rx="1" fill="#94a3b8"
              ></rect>
              <circle cx="52" cy="14" r="9" fill="#c9a227"></circle>
              <path
                d="M52 8.5 L53.8 12.3 L58 12.3 L55 14.7 L56.1 18.5 L52 16.2 L47.9 18.5 L49 14.7 L46 12.3 L50.2 12.3 Z"
                fill="white"></path>
            </svg>
          </div>
          <span
            class="font-bold text-xl"
            style="font-family: var(--font-display); color: var(--color-forest-dark);"
            >Card-O-Matic</span
          >
        </div>

        <p
          class="text-sm mb-5 max-w-xs"
          style="color: var(--color-bark-light); line-height: 1.7;"
        >
          An MCP server that gives AI the tools to create properly structured
          Linear or Jira issues — grounded in your actual codebase.
        </p>

        <!-- Think Neverland badge -->
        <div
          class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold"
          style="background-color: var(--color-cream); color: var(--color-bark-light); border: 1.5px solid var(--color-parchment-dark);"
        >
          <svg width="12" height="12" viewBox="0 0 20 20" fill="none">
            <path
              d="M10 2L11.8 7.6H17.7L12.9 11.1L14.7 16.7L10 13.2L5.3 16.7L7.1 11.1L2.3 7.6H8.2Z"
              fill="#c9a227"></path>
          </svg>
          A Think Neverland project
        </div>
      </div>

      <!-- Links column -->
      <div>
        <h4
          class="text-xs font-bold uppercase tracking-wider mb-4"
          style="color: var(--color-bark-light);"
        >
          Resources
        </h4>
        <ul class="flex flex-col gap-2.5">
          <li>
            <a
              href="https://www.npmjs.com/package/@thinkneverland/card-o-matic-mcp"
              target="_blank"
              rel="noopener noreferrer"
              class="footer-link text-sm"
            >
              npm Package
            </a>
          </li>
          <li>
            <a
              href="https://atlas.thinkneverland.com"
              target="_blank"
              rel="noopener noreferrer"
              class="footer-link text-sm"
            >
              Atlas MCP ✦
            </a>
          </li>
        </ul>
      </div>

      <!-- Docs column -->
      <div>
        <h4
          class="text-xs font-bold uppercase tracking-wider mb-4"
          style="color: var(--color-bark-light);"
        >
          On This Page
        </h4>
        <ul class="flex flex-col gap-2.5">
          <li><a href="#features" class="footer-link text-sm">Features</a></li>
          <li>
            <a href="#how-it-works" class="footer-link text-sm">How It Works</a>
          </li>
          <li><a href="#atlas" class="footer-link text-sm">Atlas MCP</a></li>
          <li>
            <a href="#install" class="footer-link text-sm">Installation</a>
          </li>
          <li>
            <a href="#card-format" class="footer-link text-sm">Card Format</a>
          </li>
          <li>
            <a href="#project-config" class="footer-link text-sm"
              >Project Config</a
            >
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="pt-8 flex items-center justify-center gap-1 text-xs"
      style="border-top: 1px solid var(--color-parchment-dark); color: var(--color-bark);"
    >
      Made with ✨ by Think Neverland | © {new Date().getFullYear()}
    </div>
  </div>
</footer>

<style>
  .footer-link {
    color: var(--color-bark-light);
    transition: color 0.15s;
    text-decoration: none;
  }
  .footer-link:hover {
    color: var(--color-forest);
  }
</style>
