---

---

<section
  id="install"
  class="py-24 px-6"
  style="background-color: var(--color-parchment);"
>
  <div class="divider-vines h-5 mb-16 opacity-40"></div>

  <div class="max-w-4xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-14">
      <div
        class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold mb-4"
        style="background-color: var(--color-parchment-dark); color: var(--color-robot); border: 1px solid rgba(100,116,139,0.2);"
      >
        🤖 Installation
      </div>
      <h2
        class="text-4xl sm:text-5xl font-bold mb-4"
        style="font-family: var(--font-display); color: var(--color-forest-dark);"
      >
        Up and running in minutes
      </h2>
      <p
        class="text-lg max-w-xl mx-auto"
        style="color: var(--color-bark-light);"
      >
        Install the package or build from source, then connect to Linear or
        Jira.
      </p>
    </div>

    <!-- Tab navigation -->
    <div
      id="install-tabs"
      class="flex flex-wrap gap-2 mb-8 p-1.5 rounded-xl"
      style="background-color: var(--color-parchment-dark);"
    >
      <button
        data-tab="linear"
        class="install-tab active flex-1 min-w-fit px-4 py-2.5 rounded-lg text-sm font-semibold transition-all duration-200"
        style=""
      >
        Linear Setup
      </button>
      <button
        data-tab="jira"
        class="install-tab flex-1 min-w-fit px-4 py-2.5 rounded-lg text-sm font-semibold transition-all duration-200"
      >
        Jira Setup
      </button>
      <button
        data-tab="source"
        class="install-tab flex-1 min-w-fit px-4 py-2.5 rounded-lg text-sm font-semibold transition-all duration-200"
      >
        From Source
      </button>
      <button
        data-tab="env"
        class="install-tab flex-1 min-w-fit px-4 py-2.5 rounded-lg text-sm font-semibold transition-all duration-200"
      >
        Env Variables
      </button>
    </div>

    <!-- Tab panels -->

    <!-- LINEAR TAB -->
    <div id="tab-linear" class="tab-panel">
      <!-- Step 1: Install -->
      <div class="step-card mb-6">
        <div class="step-header">
          <span class="step-num">1</span>
          <h3 class="step-title">Install from npm</h3>
        </div>
        <div class="code-block">
          <div class="code-topbar">
            <span class="code-dot red"></span><span class="code-dot yellow"
            ></span><span class="code-dot green"></span>
            <span class="code-filename">terminal</span>
            <button
              class="copy-btn"
              data-copy="npm install -g @thinkneverland/card-o-matic-mcp"
              >Copy</button
            >
          </div>
          <pre
            class="code-pre"><span class="code-keyword">npm</span><span class="text-code"> install -g @thinkneverland/card-o-matic-mcp</span></pre>
        </div>
        <p class="step-desc mt-3">
          Or skip the install — use <code class="inline-code">npx</code> directly
          in your MCP config and it runs without a global install.
        </p>
      </div>
      <!-- Step 2: Add to Claude -->
      <div class="step-card mb-6">
        <div class="step-header">
          <span class="step-num">2</span>
          <h3 class="step-title">Add to Claude (CLI)</h3>
        </div>
        <div class="code-block">
          <div class="code-topbar">
            <span class="code-dot red"></span><span class="code-dot yellow"
            ></span><span class="code-dot green"></span>
            <span class="code-filename">terminal</span>
            <button
              class="copy-btn"
              data-copy="claude mcp add --transport stdio --scope user \
  --env LINEAR_ACCESS_TOKEN=lin_api_XXXX \
  card-o-matic -- npx @thinkneverland/card-o-matic-mcp"
              >Copy</button
            >
          </div>
          <pre
            class="code-pre"><span class="code-keyword">claude</span><span class="text-code"> mcp add --transport stdio --scope user \
  --env </span><span class="code-key">LINEAR_ACCESS_TOKEN</span><span class="text-code">=</span><span class="code-string">lin_api_XXXX</span><span class="text-code"> \
  card-o-matic -- </span><span class="code-keyword">npx</span><span class="text-code"> @thinkneverland/card-o-matic-mcp</span></pre>
        </div>
        <p class="step-desc mt-4">
          Or edit <code class="inline-code">~/.claude.json</code> directly:
        </p>
        <div class="code-block">
          <div class="code-topbar">
            <span class="code-dot red"></span><span class="code-dot yellow"
            ></span><span class="code-dot green"></span>
            <span class="code-filename">~/.claude.json</span>
            <button
              class="copy-btn"
              data-copy='{"mcpServers":{"card-o-matic":{"type":"stdio","command":"npx","args":["@thinkneverland/card-o-matic-mcp"],"env":{"LINEAR_ACCESS_TOKEN":"lin_api_XXXX"}}}}'
              >Copy</button
            >
          </div>
          <pre
            class="code-pre"><span class="text-code">&#123;</span>
  <span class="code-key">"mcpServers"</span><span class="text-code">: &#123;</span>
    <span class="code-key">"card-o-matic"</span><span class="text-code">: &#123;</span>
      <span class="code-key">"type"</span><span class="text-code">: </span><span class="code-string">"stdio"</span><span class="text-code">,</span>
      <span class="code-key">"command"</span><span class="text-code">: </span><span class="code-string">"npx"</span><span class="text-code">,</span>
      <span class="code-key">"args"</span><span class="text-code">: [</span><span class="code-string">"@thinkneverland/card-o-matic-mcp"</span><span class="text-code">],</span>
      <span class="code-key">"env"</span><span class="text-code">: &#123;</span>
        <span class="code-key">"LINEAR_ACCESS_TOKEN"</span><span class="text-code">: </span><span class="code-string">"lin_api_XXXX"</span>
      <span class="text-code">&#125;</span>
    <span class="text-code">&#125;</span>
  <span class="text-code">&#125;</span>
<span class="text-code">&#125;</span></pre>
        </div>
      </div>
    </div>

    <!-- JIRA TAB -->
    <div id="tab-jira" class="tab-panel hidden">
      <div class="step-card mb-6">
        <div class="step-header">
          <span class="step-num">1</span>
          <h3 class="step-title">Install from npm</h3>
        </div>
        <div class="code-block">
          <div class="code-topbar">
            <span class="code-dot red"></span><span class="code-dot yellow"
            ></span><span class="code-dot green"></span>
            <span class="code-filename">terminal</span>
            <button
              class="copy-btn"
              data-copy="npm install -g @thinkneverland/card-o-matic-mcp"
              >Copy</button
            >
          </div>
          <pre
            class="code-pre"><span class="code-keyword">npm</span><span class="text-code"> install -g @thinkneverland/card-o-matic-mcp</span></pre>
        </div>
        <p class="step-desc mt-3">
          Or skip the install — use <code class="inline-code">npx</code> directly
          in your MCP config and it runs without a global install.
        </p>
      </div>
      <div class="step-card mb-6">
        <div class="step-header">
          <span class="step-num">2</span>
          <h3 class="step-title">Add to Claude with Jira (CLI)</h3>
        </div>
        <div class="code-block">
          <div class="code-topbar">
            <span class="code-dot red"></span><span class="code-dot yellow"
            ></span><span class="code-dot green"></span>
            <span class="code-filename">terminal</span>
            <button
              class="copy-btn"
              data-copy="claude mcp add --transport stdio --scope user \
  --env CARD_O_MATIC_PROVIDER=jira \
  --env JIRA_BASE_URL=https://yourorg.atlassian.net \
  --env JIRA_EMAIL=you@yourorg.com \
  --env JIRA_API_TOKEN=XXXX \
  --env JIRA_PROJECT_KEY=TN \
  card-o-matic -- npx @thinkneverland/card-o-matic-mcp"
              >Copy</button
            >
          </div>
          <pre
            class="code-pre"><span class="code-keyword">claude</span><span class="text-code"> mcp add --transport stdio --scope user \
  --env </span><span class="code-key">CARD_O_MATIC_PROVIDER</span><span class="text-code">=</span><span class="code-string">jira</span><span class="text-code"> \
  --env </span><span class="code-key">JIRA_BASE_URL</span><span class="text-code">=</span><span class="code-string">https://yourorg.atlassian.net</span><span class="text-code"> \
  --env </span><span class="code-key">JIRA_EMAIL</span><span class="text-code">=</span><span class="code-string">you@yourorg.com</span><span class="text-code"> \
  --env </span><span class="code-key">JIRA_API_TOKEN</span><span class="text-code">=</span><span class="code-string">XXXX</span><span class="text-code"> \
  --env </span><span class="code-key">JIRA_PROJECT_KEY</span><span class="text-code">=</span><span class="code-string">TN</span><span class="text-code"> \
  card-o-matic -- </span><span class="code-keyword">npx</span><span class="text-code"> @thinkneverland/card-o-matic-mcp</span></pre>
        </div>
      </div>

      <div class="step-card mb-6">
        <div class="step-header">
          <span class="step-num">3</span>
          <h3 class="step-title">
            Or edit <code class="inline-code-white">~/.claude.json</code>
          </h3>
        </div>
        <div class="code-block">
          <div class="code-topbar">
            <span class="code-dot red"></span><span class="code-dot yellow"
            ></span><span class="code-dot green"></span>
            <span class="code-filename">~/.claude.json</span>
            <button
              class="copy-btn"
              data-copy='{"mcpServers":{"card-o-matic":{"type":"stdio","command":"npx","args":["@thinkneverland/card-o-matic-mcp"],"env":{"CARD_O_MATIC_PROVIDER":"jira","JIRA_BASE_URL":"https://yourorg.atlassian.net","JIRA_EMAIL":"you@yourorg.com","JIRA_API_TOKEN":"XXXX","JIRA_PROJECT_KEY":"TN"}}}}'
              >Copy</button
            >
          </div>
          <pre
            class="code-pre"><span class="text-code">&#123;</span>
  <span class="code-key">"mcpServers"</span><span class="text-code">: &#123;</span>
    <span class="code-key">"card-o-matic"</span><span class="text-code">: &#123;</span>
      <span class="code-key">"type"</span><span class="text-code">: </span><span class="code-string">"stdio"</span><span class="text-code">,</span>
      <span class="code-key">"command"</span><span class="text-code">: </span><span class="code-string">"npx"</span><span class="text-code">,</span>
      <span class="code-key">"args"</span><span class="text-code">: [</span><span class="code-string">"@thinkneverland/card-o-matic-mcp"</span><span class="text-code">],</span>
      <span class="code-key">"env"</span><span class="text-code">: &#123;</span>
        <span class="code-key">"CARD_O_MATIC_PROVIDER"</span><span class="text-code">: </span><span class="code-string">"jira"</span><span class="text-code">,</span>
        <span class="code-key">"JIRA_BASE_URL"</span><span class="text-code">: </span><span class="code-string">"https://yourorg.atlassian.net"</span><span class="text-code">,</span>
        <span class="code-key">"JIRA_EMAIL"</span><span class="text-code">: </span><span class="code-string">"you@yourorg.com"</span><span class="text-code">,</span>
        <span class="code-key">"JIRA_API_TOKEN"</span><span class="text-code">: </span><span class="code-string">"XXXX"</span><span class="text-code">,</span>
        <span class="code-key">"JIRA_PROJECT_KEY"</span><span class="text-code">: </span><span class="code-string">"TN"</span>
      <span class="text-code">&#125;</span>
    <span class="text-code">&#125;</span>
  <span class="text-code">&#125;</span>
<span class="text-code">&#125;</span></pre>
        </div>
      </div>
    </div>

    <!-- SOURCE TAB -->
    <div id="tab-source" class="tab-panel hidden">
      <div class="step-card mb-6">
        <div class="step-header">
          <span class="step-num">1</span>
          <h3 class="step-title">Clone and build</h3>
        </div>
        <div class="code-block">
          <div class="code-topbar">
            <span class="code-dot red"></span><span class="code-dot yellow"
            ></span><span class="code-dot green"></span>
            <span class="code-filename">terminal</span>
            <button
              class="copy-btn"
              data-copy="cd card-o-matic-mcp
npm install
npm run build"
              >Copy</button
            >
          </div>
          <pre
            class="code-pre"><span class="code-keyword">cd</span><span class="text-code"> card-o-matic-mcp
</span><span class="code-keyword">npm</span><span class="text-code"> install
</span><span class="code-keyword">npm</span><span class="text-code"> run build</span></pre>
        </div>
      </div>
      <div class="step-card">
        <div class="step-header">
          <span class="step-num">2</span>
          <h3 class="step-title">Register with Claude</h3>
        </div>
        <p class="step-desc">
          Use the absolute path to the built <code class="inline-code"
            >dist/index.js</code
          >. See the Linear or Jira tabs for the full MCP config.
        </p>
        <div
          class="mt-4 p-4 rounded-xl"
          style="background: rgba(45,106,79,0.08); border: 1.5px solid rgba(45,106,79,0.2);"
        >
          <p class="text-sm" style="color: var(--color-forest-dark);">
            <span class="font-semibold">Node requirement:</span> Node.js ≥ 20 required.
          </p>
        </div>
      </div>
    </div>

    <!-- ENV TAB -->
    <div id="tab-env" class="tab-panel hidden">
      <div
        class="overflow-x-auto rounded-2xl"
        style="border: 1.5px solid var(--color-parchment-dark);"
      >
        <table class="w-full text-sm">
          <thead>
            <tr style="background-color: var(--color-parchment-dark);">
              <th
                class="text-left px-5 py-3 font-semibold"
                style="color: var(--color-forest-dark);">Variable</th
              >
              <th
                class="text-left px-5 py-3 font-semibold"
                style="color: var(--color-forest-dark);">Provider</th
              >
              <th
                class="text-left px-5 py-3 font-semibold"
                style="color: var(--color-forest-dark);">Required</th
              >
              <th
                class="text-left px-5 py-3 font-semibold"
                style="color: var(--color-forest-dark);">Description</th
              >
            </tr>
          </thead>
          <tbody>
            {
              [
                {
                  var: "CARD_O_MATIC_PROVIDER",
                  provider: "—",
                  req: "No",
                  desc: "linear (default) or jira",
                },
                {
                  var: "LINEAR_ACCESS_TOKEN",
                  provider: "Linear",
                  req: "Yes",
                  desc: "Linear API key or OAuth token",
                },
                {
                  var: "JIRA_BASE_URL",
                  provider: "Jira",
                  req: "Yes",
                  desc: "e.g. https://yourorg.atlassian.net",
                },
                {
                  var: "JIRA_EMAIL",
                  provider: "Jira",
                  req: "Yes",
                  desc: "Atlassian account email",
                },
                {
                  var: "JIRA_API_TOKEN",
                  provider: "Jira",
                  req: "Yes",
                  desc: "Atlassian API token",
                },
                {
                  var: "JIRA_PROJECT_KEY",
                  provider: "Jira",
                  req: "Yes",
                  desc: "Default project key (e.g. TN)",
                },
                {
                  var: "CARD_O_MATIC_HIDE_FOOTER",
                  provider: "—",
                  req: "No",
                  desc: "Set to true to suppress the footer on all cards",
                },
              ].map((row, i) => (
                <tr
                  style={`background-color: ${i % 2 === 0 ? "var(--color-cream)" : "var(--color-parchment)"};`}
                >
                  <td class="px-5 py-3.5">
                    <code
                      class="text-xs font-mono font-semibold"
                      style="color: var(--color-forest);"
                    >
                      {row.var}
                    </code>
                  </td>
                  <td
                    class="px-5 py-3.5 text-xs"
                    style="color: var(--color-bark-light);"
                  >
                    {row.provider}
                  </td>
                  <td class="px-5 py-3.5">
                    <span
                      class={`text-xs font-semibold px-2 py-0.5 rounded-full ${row.req === "Yes" ? "bg-orange-100 text-orange-700" : "bg-gray-100 text-gray-500"}`}
                    >
                      {row.req}
                    </span>
                  </td>
                  <td
                    class="px-5 py-3.5 text-xs"
                    style="color: var(--color-bark-light);"
                  >
                    {row.desc}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<style>
  .step-card {
    background-color: var(--color-cream);
    border: 1.5px solid var(--color-parchment-dark);
    border-radius: 1rem;
    padding: 1.5rem;
  }
  .step-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .step-num {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
    background-color: var(--color-forest);
    color: white;
  }
  .step-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-forest-dark);
    font-family: var(--font-display);
  }
  .step-desc {
    font-size: 0.875rem;
    color: var(--color-bark-light);
  }
  .inline-code {
    font-family: var(--font-mono);
    font-size: 0.8em;
    padding: 0.1em 0.4em;
    border-radius: 0.25rem;
    background-color: var(--color-parchment-dark);
    color: var(--color-forest-dark);
  }
  .inline-code-white {
    font-family: var(--font-mono);
    font-size: 0.8em;
    padding: 0.1em 0.4em;
    border-radius: 0.25rem;
    background-color: rgba(255, 255, 255, 0.15);
    color: inherit;
  }
  .code-block {
    border-radius: 0.875rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.06);
    margin-top: 0.75rem;
  }
  .code-topbar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1rem;
    background-color: #0f172a;
  }
  .code-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .code-dot.red {
    background-color: #ff5f56;
  }
  .code-dot.yellow {
    background-color: #ffbd2e;
  }
  .code-dot.green {
    background-color: #27c93f;
  }
  .code-filename {
    flex: 1;
    text-align: center;
    font-size: 0.72rem;
    font-family: var(--font-mono);
    color: rgba(255, 255, 255, 0.35);
    margin-left: -1.5rem;
  }
  .copy-btn {
    font-size: 0.7rem;
    font-family: var(--font-sans);
    padding: 0.2rem 0.6rem;
    border-radius: 0.3rem;
    background-color: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    border: none;
    transition: all 0.15s;
    flex-shrink: 0;
  }
  .copy-btn:hover {
    background-color: rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.8);
  }
  .code-pre {
    background-color: var(--color-code-bg);
    padding: 1rem 1.25rem;
    overflow-x: auto;
    font-size: 0.82rem;
    line-height: 1.65;
    margin: 0;
    font-family: var(--font-mono);
    white-space: pre;
  }
  .install-tab {
    color: var(--color-bark-light);
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .install-tab.active {
    background-color: var(--color-cream);
    color: var(--color-forest-dark);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
  }
  .install-tab:hover:not(.active) {
    color: var(--color-bark);
  }
</style>

<script>
  // Tab switching
  const tabs = document.querySelectorAll(".install-tab");
  const panels = document.querySelectorAll(".tab-panel");

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const target = (tab as HTMLElement).dataset.tab;
      tabs.forEach((t) => t.classList.remove("active"));
      tab.classList.add("active");
      panels.forEach((p) => {
        if (p.id === `tab-${target}`) {
          p.classList.remove("hidden");
        } else {
          p.classList.add("hidden");
        }
      });
    });
  });

  // Copy buttons
  document.querySelectorAll(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const text = (btn as HTMLElement).dataset.copy || "";
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = "Copied!";
        setTimeout(() => (btn.textContent = "Copy"), 1800);
      });
    });
  });
</script>
