---
const params = [
  { param: "atlasRoutes", source: "get_project_surface type=routes", section: "Affected Routes" },
  { param: "atlasTestPatterns", source: "get_test_patterns", section: "Test Conventions" },
  { param: "atlasHotspots", source: "get_project_health type=hotspots", section: "Hotspots" },
  { param: "atlasCoverageGaps", source: "get_project_health type=coverage", section: "Coverage Gaps" },
  { param: "atlasDomainContext", source: "get_project_surface type=domain", section: "Domain Context" },
];
---

<section id="atlas" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="rounded-3xl overflow-hidden" style="background: linear-gradient(160deg, var(--color-forest-dark) 0%, #1b4332 50%, #0f2d1e 100%);">
      <div class="grid lg:grid-cols-2 gap-0">
        <!-- Left: Content -->
        <div class="p-10 lg:p-14">
          <!-- Header -->
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold mb-6" style="background: rgba(201,162,39,0.2); color: var(--color-gold-light); border: 1px solid rgba(201,162,39,0.3);">
            ✦ Superpower Unlocked
          </div>

          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4" style="font-family: var(--font-display);">
            Supercharge with<br/>
            <span style="color: var(--color-gold-light);">Atlas MCP</span>
          </h2>

          <p class="text-base mb-8 leading-relaxed" style="color: rgba(255,255,255,0.7);">
            Run the <a href="https://atlas.thinkneverland.com" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 font-semibold" style="color: var(--color-forest-light);">Atlas MCP server</a> alongside Card-O-Matic and your AI agent becomes a bridge — piping live project intelligence directly into every card it creates.
          </p>

          <!-- How it works explanation -->
          <div class="flex flex-col gap-4 mb-10">
            <div class="flex items-start gap-3">
              <div class="w-7 h-7 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5" style="background: rgba(82,183,136,0.2);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#52b788" stroke-width="2.5" stroke-linecap="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <p class="text-sm" style="color: rgba(255,255,255,0.75);">
                AI calls <code class="px-1.5 py-0.5 rounded text-xs" style="background:rgba(255,255,255,0.1);color:#86efac;font-family:var(--font-mono);">atlas_mcp.get_project_surface</code> and pipes routes into your card
              </p>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-7 h-7 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5" style="background: rgba(82,183,136,0.2);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#52b788" stroke-width="2.5" stroke-linecap="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <p class="text-sm" style="color: rgba(255,255,255,0.75);">
                Hotspots and coverage gaps automatically populate the AI Implementation Guidance section
              </p>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-7 h-7 rounded-lg flex-shrink-0 flex items-center justify-center mt-0.5" style="background: rgba(82,183,136,0.2);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#52b788" stroke-width="2.5" stroke-linecap="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <p class="text-sm" style="color: rgba(255,255,255,0.75);">
                All Atlas params are <em>optional</em> — cards work perfectly without them. Atlas just makes them richer.
              </p>
            </div>
          </div>

          <!-- CTAs -->
          <div class="flex flex-wrap gap-3">
            <a
              href="https://atlas.thinkneverland.com"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-semibold text-sm transition-all duration-200 hover:opacity-90 hover:-translate-y-0.5"
              style="background-color: var(--color-gold); color: var(--color-forest-dark);"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              Visit Atlas MCP →
            </a>
            <a
              href="#install"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-semibold text-sm transition-all duration-200 hover:-translate-y-0.5"
              style="background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.85); border: 1px solid rgba(255,255,255,0.2);"
            >
              See Install Docs
            </a>
          </div>
        </div>

        <!-- Right: Parameter table -->
        <div class="lg:p-10 p-8 lg:pt-14 flex flex-col justify-center">
          <h3 class="text-sm font-semibold uppercase tracking-wider mb-5" style="color: rgba(255,255,255,0.4);">Atlas MCP Bridge Parameters</h3>

          <div class="flex flex-col gap-3">
            {params.map((p) => (
              <div class="rounded-xl p-4" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);">
                <div class="flex items-start gap-3">
                  <div class="flex-shrink-0 w-1.5 h-1.5 rounded-full mt-2" style="background-color: var(--color-forest-light);"></div>
                  <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-center gap-2 mb-1">
                      <code class="text-xs font-semibold px-2 py-0.5 rounded" style="background: rgba(82,183,136,0.15); color: #86efac; font-family: var(--font-mono);">{p.param}</code>
                      <span class="text-xs" style="color: rgba(255,255,255,0.35);">→</span>
                      <span class="text-xs font-semibold" style="color: var(--color-gold-light);">{p.section}</span>
                    </div>
                    <p class="text-xs" style="color: rgba(255,255,255,0.45); font-family: var(--font-mono);">
                      atlas: <span style="color: rgba(255,255,255,0.6);">{p.source}</span>
                    </p>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <!-- Local atlas context note -->
          <div class="mt-5 p-4 rounded-xl" style="background: rgba(201,162,39,0.1); border: 1px solid rgba(201,162,39,0.2);">
            <p class="text-xs" style="color: rgba(255,255,255,0.65);">
              <span style="color: var(--color-gold-light); font-weight: 600;">No Atlas MCP server?</span> Add a <code style="color: #86efac; font-family: var(--font-mono);">.atlas/</code> directory to your project with docs and playbooks. The <code style="color: #86efac; font-family: var(--font-mono);">atlas_context</code> tool reads them locally, automatically.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
